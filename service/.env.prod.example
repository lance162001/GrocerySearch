# Copy this file to .env.prod and fill in real values before deployment.

# ----- API Runtime -----
API_PORT=8000
UVICORN_WORKERS=2
ALLOWED_ORIGINS=https://yourdomain.com
DISABLE_DOCS=1

# ----- Frontend Runtime/Build -----
FRONTEND_PORT=3000
# Keep true when frontend should call this deployment's backend.
FRONTEND_USE_LOCAL_BACKEND=true
# Optional overrides for Flutter web build.
LOCAL_BACKEND_HOST=
LOCAL_BACKEND_PORT=8000
# Route web API calls through the frontend container, then proxy to the api service.
FRONTEND_WEB_USE_SAME_ORIGIN_API=true
FRONTEND_WEB_API_PATH_PREFIX=/api

# ----- Database -----
POSTGRES_DB=grocerysearch
POSTGRES_USER=grocerysearch
POSTGRES_PASSWORD=change-this
# Optional: leave unset to use the derived DSN in docker-compose.prod.yml
# DATABASE_URL=postgresql://grocerysearch:change-this@db:5432/grocerysearch
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ----- Scraper Integrations -----
ALGOLIA_APP_ID=QGPPR19V8V
ALGOLIA_API_KEY=
# The production scraper service starts with --run-on-start (non-debug),
# so initial data is scraped during deployment and daily scheduling continues.

# ----- Email Summary -----
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_RECEIVER=
# Base URL of the frontend app — used to generate newsletter bundle and unsubscribe links.
BASE_URL=https://yourdomain.com
