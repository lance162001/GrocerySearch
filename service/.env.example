# ── Database ────────────────────────────────────────────────────
# For production use PostgreSQL, e.g.:
#   DATABASE_URL=postgresql://user:password@host:5432/grocerysearch
# Leave unset to default to local SQLite (service/app.db).
DATABASE_URL=
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── CORS ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
ALLOWED_ORIGINS=https://yourdomain.com

# ── Algolia (Wegmans scraper) ──────────────────────────────────
ALGOLIA_APP_ID=QGPPR19V8V
ALGOLIA_API_KEY=

# ── Email / SMTP ───────────────────────────────────────────────
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_RECEIVER=

# ── App URL ─────────────────────────────────────────────────────
# Base URL of the frontend app — used to generate newsletter bundle and unsubscribe links.
BASE_URL=http://localhost:3000

# ── Misc ───────────────────────────────────────────────────────
# Set to any value to hide /docs and /redoc in production.
# DISABLE_DOCS=1
